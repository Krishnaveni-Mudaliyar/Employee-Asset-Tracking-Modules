enum 50101 "AST Asset Condition"
{
    Extensible = true;

    value(0; "")
    {
        Caption = '';
    }
    value(1; Excellent)
    {
        Caption = 'Excellent';
    }
    value(2; New)
    {
        Caption = 'New';
    }
    value(3; Good)
    {
        Caption = 'Good';
    }
    value(4; Fair)
    {
        Caption = 'Fair';
    }
    value(5; Poor)
    {
        Caption = 'Poor';
    }
    value(6; Damaged)
    {
        Caption = 'Damaged';
    }
}
