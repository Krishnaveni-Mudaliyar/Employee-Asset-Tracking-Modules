enum 50101 "AST Asset Condition"
{
    Extensible = true;

    value(0; "")
    {
        Caption = '';
    }
    value(1; New)
    {
        Caption = 'New';
    }
    value(2; Good)
    {
        Caption = 'Good';
    }
    value(3; Fair)
    {
        Caption = 'Fair';
    }
    value(4; Poor)
    {
        Caption = 'Poor';
    }
    value(5; Damaged)
    {
        Caption = 'Damaged';
    }
}
