enum 50103 "AST Asset Category Type"
{
    Extensible = true;

    value(0; "")
    {
        Caption = '';
    }
    value(1; "IT Equipment")
    {
        Caption = 'IT Equipment';
    }
    value(2; Furniture)
    {
        Caption = 'Furniture';
    }
    value(3; Vehicle)
    {
        Caption = 'Vehicle';
    }
    value(4; Machinery)
    {
        Caption = 'Machinery';
    }
    value(5; Other)
    {
        caption = 'Other';
    }
}
