enum 50100 "AST Asset Status"
{
    Extensible = true;

    value(0; "")
    {
        Caption = '';
    }
    value(1; Available)
    {
        Caption = 'Available';
    }
    value(2; Assigned)
    {
        Caption = 'Assigned';
    }
    value(3; "Under Maintainence")
    {
        Caption = 'Under Maintainence';
    }
    value(4; Disposed)
    {
        Caption = 'Disposed';
    }
    value(5; Lost)
    {
        Caption = 'Lost';
    }
}
